{
  "description": "AI特征模式库 — 检测器识别的AI文本特征",
  "version": "1.0.0",
  "detectors": {
    "GLTR": {
      "patterns": [
        {
          "name": "高概率token聚集",
          "description": "AI文本中高概率token占比过高",
          "detection_method": "Test 1 - 计算top-10 token覆盖率",
          "threshold": "> 0.7",
          "counter_strategy": "高温解码 + 同义词替换"
        },
        {
          "name": "token排名偏向头部",
          "description": "选择的token排名过于靠前",
          "detection_method": "Test 2 - 排名分布直方图",
          "threshold": "rank < 10 占比 > 60%",
          "counter_strategy": "top_p=0.85-0.92 + frequency_penalty"
        },
        {
          "name": "分布熵过低",
          "description": "token选择的不确定性过低",
          "detection_method": "Test 3 - 熵值计算",
          "threshold": "< 2.5",
          "counter_strategy": "句长随机化 + 结构重组"
        }
      ]
    },
    "GPTZero": {
      "patterns": [
        {
          "name": "低perplexity",
          "description": "文本整体困惑度过低",
          "detection_method": "困惑度计算",
          "threshold": "< 50",
          "counter_strategy": "同义词替换 + 词汇多样化"
        },
        {
          "name": "低burstiness",
          "description": "句长过于均匀，缺乏突发性",
          "detection_method": "句长方差",
          "threshold": "标准差 < 5",
          "counter_strategy": "句长随机化（5-50字混合）"
        }
      ]
    },
    "DetectGPT": {
      "patterns": [
        {
          "name": "负曲率区域",
          "description": "AI文本位于对数概率负曲率区域",
          "detection_method": "条件概率曲率",
          "threshold": "曲率 < -0.1",
          "counter_strategy": "打散模板句 + 改变句子边界"
        }
      ]
    },
    "RADAR": {
      "patterns": [
        {
          "name": "深层结构特征",
          "description": "对抗训练分类器识别的句法/段落模式",
          "detection_method": "RoBERTa分类器",
          "threshold": "置信度 > 0.7",
          "counter_strategy": "结构重组 + 句首多样化"
        }
      ]
    },
    "Simpson": {
      "patterns": [
        {
          "name": "过度自信",
          "description": "指令微调模型的过度自信导致似然假设成立",
          "detection_method": "似然检测",
          "threshold": "token级似然异常高",
          "counter_strategy": "注入不确定性 + 限定词"
        }
      ]
    }
  },
  "common_templates": {
    "四段式递进": {
      "pattern": "首先...然后...接着...最后",
      "frequency": "极高",
      "detection_rate": "> 95%",
      "variants": [
        "第一...其次...再者...最终",
        "起初...继而...随后...归根结底",
        "开端...进而...接着...末了"
      ]
    },
    "总分总结构": {
      "pattern": "背景陈述 → 分点论证 → 总结升华",
      "frequency": "高",
      "detection_rate": "> 80%",
      "counter_strategy": "分-总、总-分、夹叙夹议"
    },
    "万能过渡": {
      "patterns": [
        "值得注意的是",
        "不言而喻",
        "综上所述",
        "由此可见",
        "在...背景下",
        "随着...的发展"
      ],
      "frequency": "极高",
      "detection_rate": "> 90%"
    },
    "研究动词重复": {
      "pattern": "研究表明...研究发现...研究方法...研究结果",
      "frequency": "高",
      "detection_rate": "> 75%",
      "variants": [
        "实验、调查、探究、分析、考察"
      ]
    }
  },
  "high_risk_phrases": [
    "值得注意的是",
    "不言而喻",
    "综上所述",
    "由此可见",
    "具有重要意义",
    "在...背景下",
    "随着...的发展",
    "越来越",
    "起到了...作用",
    "产生了...影响",
    "受到了...",
    "进行了...",
    "本文首先",
    "本文通过",
    "本研究旨在"
  ],
  "paragraph_type_risk": {
    "摘要": {
      "risk_level": "极高",
      "typical_ai_score": "0.75-0.90",
      "reason": "模板句式+过渡词+万能动词密集",
      "focus_areas": ["模板句", "过渡词", "动词重复"]
    },
    "引言背景": {
      "risk_level": "高",
      "typical_ai_score": "0.70-0.85",
      "reason": "随着...发展 + 在...背景下模式",
      "focus_areas": ["句首模式", "连接词"]
    },
    "文献综述": {
      "risk_level": "高",
      "typical_ai_score": "0.65-0.80",
      "reason": "列举式 X发现...Y提出...",
      "focus_areas": ["动词变体", "句首多样化"]
    },
    "方法": {
      "risk_level": "中",
      "typical_ai_score": "0.45-0.65",
      "reason": "技术术语占比高，天然低perplexity",
      "focus_areas": ["句长微调"]
    },
    "结果分析": {
      "risk_level": "中高",
      "typical_ai_score": "0.60-0.75",
      "reason": "数据描述模板",
      "focus_areas": ["句首多样化", "同义词"]
    },
    "讨论": {
      "risk_level": "极高",
      "typical_ai_score": "0.75-0.90",
      "reason": "论述模板+过度自信",
      "focus_areas": ["结构重组", "注入不完美"]
    },
    "结论": {
      "risk_level": "高",
      "typical_ai_score": "0.70-0.85",
      "reason": "综上所述+具有意义模板",
      "focus_areas": ["模板打散", "句长", "句首"]
    }
  },
  "statistical_thresholds": {
    "sentence_length": {
      "ai_typical": {
        "mean": "15-25字",
        "std_dev": "< 5"
      },
      "human_typical": {
        "mean": "10-30字",
        "std_dev": "> 8"
      },
      "target": {
        "min_length": 5,
        "max_length": 50,
        "std_dev": "> 8"
      }
    },
    "word_frequency": {
      "ai_typical": "高频词重复 > 5次",
      "target": "高频词重复 ≤ 3次"
    },
    "punctuation_diversity": {
      "ai_typical": "逗号占比 > 70%",
      "target": "逗号占比 < 60%, 分号/破折号混合"
    },
    "sentence_starter_diversity": {
      "ai_typical": "4-5种句首模式",
      "target": "> 10种句首模式"
    }
  }
}
