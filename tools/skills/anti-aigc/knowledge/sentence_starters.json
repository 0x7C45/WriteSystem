{
  "description": "句首多样化库 — 打破AI典型的句首模式",
  "version": "1.0.0",
  "ai_typical_starters": {
    "high_frequency": [
      "本文",
      "本研究",
      "随着",
      "因此",
      "此外",
      "然而",
      "首先",
      "其次",
      "最后",
      "通过",
      "在...中",
      "在...下"
    ],
    "pattern_analysis": {
      "concentration": "AI文本中4-5种句首占比 > 60%",
      "repetition": "相邻句子句首雷同概率 > 40%",
      "target": "10+种句首模式，相邻重复率 < 10%"
    }
  },
  "diverse_starters": {
    "主语开头": {
      "名词主语": [
        "研究结果",
        "实验数据",
        "调查发现",
        "分析表明",
        "这一现象",
        "该方法",
        "这项研究",
        "相关文献",
        "现有证据",
        "学界共识"
      ],
      "代词主语": [
        "它",
        "这",
        "其",
        "该",
        "此"
      ]
    },
    "状语开头": {
      "时间状语": [
        "近年来",
        "当前",
        "目前",
        "早期",
        "21世纪以来",
        "过去十年间",
        "新近"
      ],
      "地点状语": [
        "在实践中",
        "从实证层面",
        "就理论维度",
        "于学术界",
        "在该领域"
      ],
      "方式状语": [
        "通过...方法",
        "借助...手段",
        "依据...原理",
        "基于...框架",
        "沿着...路径"
      ],
      "条件状语": [
        "若",
        "倘若",
        "假如",
        "在...条件下",
        "当...时"
      ]
    },
    "动词开头": [
      "观察到",
      "发现",
      "揭示了",
      "证实",
      "验证",
      "考察",
      "探究",
      "分析",
      "检验",
      "评估"
    ],
    "从句开头": [
      "尽管...",
      "虽然...",
      "即便...",
      "无论...",
      "不管...",
      "哪怕..."
    ],
    "引用开头": [
      "Smith等人指出",
      "据Zhang (2020)研究",
      "文献表明",
      "有学者认为",
      "多项研究证实"
    ],
    "疑问开头": [
      "如何",
      "为何",
      "何以",
      "是否",
      "能否"
    ],
    "数据开头": [
      "数据显示",
      "统计结果表明",
      "实验表明",
      "测量结果",
      "观测值"
    ]
  },
  "replacement_strategies": {
    "摘要段": {
      "avoid": ["本文", "本研究"],
      "prefer": ["该研究", "这项工作", "直接陈述主语"],
      "example": "本文探讨... → 该研究探讨... / 人工智能技术的应用..."
    },
    "引言段": {
      "avoid": ["随着...的发展", "在...背景下"],
      "prefer": ["时间状语", "现象描述", "问题陈述"],
      "example": "随着AI发展... → 近年来AI技术... / AI技术的快速发展..."
    },
    "文献综述": {
      "avoid": ["首先...其次...最后"],
      "prefer": ["引用开头", "学者名字", "时间顺序"],
      "example": "首先Smith研究... → Smith等人(2019)发现... / 早期研究聚焦于..."
    },
    "方法段": {
      "avoid": ["本文采用", "本研究使用"],
      "prefer": ["直接动词开头", "方法名称"],
      "example": "本文采用问卷法... → 问卷调查覆盖... / 研究采用混合方法..."
    },
    "结果段": {
      "avoid": ["结果表明", "数据显示"],
      "prefer": ["具体数据", "具体发现"],
      "example": "结果表明差异显著 → 两组间差异达到显著水平(p<0.01)"
    },
    "讨论段": {
      "avoid": ["本研究发现", "本文认为"],
      "prefer": ["现象描述", "因果分析", "对比陈述"],
      "example": "本研究发现X与Y正相关 → X与Y之间的正相关关系验证了..."
    },
    "结论段": {
      "avoid": ["综上所述", "总之"],
      "prefer": ["直接陈述结论", "研究贡献"],
      "example": "综上所述，本研究... → 该研究在三个方面有所贡献：..."
    }
  },
  "diversification_rules": {
    "no_repetition": "相邻句子句首不重复",
    "pattern_mixing": "在一个段落中混合使用至少3种句首类型",
    "context_appropriate": "根据段落功能选择合适的句首",
    "natural_flow": "句首变化不影响逻辑连贯性",
    "avoid_forced": "不为多样化而牺牲表达准确性"
  },
  "paragraph_level_strategy": {
    "short_paragraph": {
      "sentence_count": "3-5句",
      "starter_types": "2-3种",
      "recommendation": "至少1句非典型AI句首"
    },
    "medium_paragraph": {
      "sentence_count": "6-10句",
      "starter_types": "4-5种",
      "recommendation": "至少2句非典型AI句首"
    },
    "long_paragraph": {
      "sentence_count": "11+句",
      "starter_types": "6+种",
      "recommendation": "分段或确保句首高度多样化"
    }
  },
  "advanced_techniques": {
    "sentence_inversion": {
      "description": "倒装句增加变化",
      "examples": [
        "在理论层面 → 理论层面上",
        "对于这个问题 → 这个问题需要...",
        "关于方法选择 → 方法选择依据..."
      ]
    },
    "merge_sentences": {
      "description": "合并短句以改变句首",
      "example": "本文分析数据。数据来自... → 本文分析的数据来自..."
    },
    "split_sentences": {
      "description": "拆分长句创造新句首",
      "example": "本文通过X方法分析Y问题并得出Z结论 → 本文聚焦Y问题。研究采用X方法。分析得出Z结论。"
    }
  },
  "quality_checklist": [
    "✓ 相邻句首无重复",
    "✓ 段落内句首类型 ≥ 3种",
    "✓ 避免AI高频句首（本文/本研究/随着/因此）占比 > 50%",
    "✓ 学术语气保持专业",
    "✓ 逻辑连贯性不受影响"
  ],
  "notes": [
    "句首多样化是对抗神经网络分类器的有效手段",
    "RoBERTa等分类器的注意力头高度关注句首模式",
    "自然的句首变化优于机械的轮换",
    "句首改变需配合句式结构调整"
  ]
}
