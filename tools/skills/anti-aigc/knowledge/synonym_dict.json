{
  "description": "同义词替换词典 — 降低AI特征的词汇替换库",
  "version": "1.0.0",
  "categories": {
    "高频虚词": {
      "具有...的": ["带有...的", "富含...的", "拥有...特性的", "呈现...特点的"],
      "在...背景下": ["鉴于...情况", "考虑到...因素", "面对...环境", "处于...条件中"],
      "受到了...": ["得到了...", "获得了...", "经历了...", "遭遇了..."],
      "进行了...": ["开展了...", "实施了...", "执行了...", "完成了..."],
      "起到了...作用": ["发挥了...功能", "产生了...效果", "带来了...影响", "实现了...目标"],
      "产生了...影响": ["造成了...后果", "引发了...变化", "带来了...结果", "导致了...效应"]
    },
    "学术连接词": {
      "首先": ["第一", "首要的是", "最初", "开端在于"],
      "然后": ["接着", "其次", "随后", "继而"],
      "接着": ["之后", "紧接着", "再者", "进而"],
      "最后": ["最终", "末了", "终究", "归根结底"],
      "此外": ["同时", "另一方面", "从另一个角度看", "补充来说"],
      "因此": ["由此", "基于上述分析", "这一发现表明", "据此可知"],
      "综上所述": ["总的来说", "概括而言", "归纳上述观点", "综合以上论述"]
    },
    "模板短语": {
      "值得注意的是": ["需要指出", "特别值得关注", "重要的一点是", "应该强调"],
      "不言而喻": ["显而易见", "毋庸置疑", "不难发现", "清楚表明"],
      "越来越": ["日益", "逐渐", "持续", "不断"],
      "随着...的发展": ["伴随...进程", "...演进过程中", "在...推动下", "...变革背景下"],
      "在...方面": ["于...领域", "就...而言", "关于...问题", "涉及...维度"],
      "具有重要意义": ["意义深远", "影响显著", "价值突出", "作用关键"]
    },
    "研究动词": {
      "研究表明": ["研究发现", "实验证实", "数据显示", "分析揭示"],
      "研究发现": ["调查表明", "考察结果", "探究显示", "观察发现"],
      "研究方法": ["研究路径", "研究手段", "研究途径", "研究策略"],
      "研究结果": ["研究成果", "研究产出", "研究发现", "实验结论"],
      "分析表明": ["分析显示", "剖析结果", "解析发现", "考察显示"]
    },
    "学术形容词": {
      "重要的": ["关键的", "核心的", "主要的", "显著的"],
      "有效的": ["行之有效的", "可行的", "实用的", "高效的"],
      "显著的": ["明显的", "突出的", "鲜明的", "显著性的"],
      "复杂的": ["繁复的", "多元的", "错综复杂的", "多维的"],
      "全面的": ["综合的", "系统的", "整体的", "完备的"]
    },
    "论证句首": {
      "本文": ["本研究", "本论文", "本文章", "这项研究"],
      "随着": ["伴随", "伴随着", "随之", "依随"],
      "因此": ["故而", "由此", "据此", "基于此"],
      "此外": ["另外", "除此之外", "再者", "且"],
      "然而": ["不过", "但是", "可是", "只是"]
    }
  },
  "replacement_rules": {
    "min_coverage": 0.6,
    "max_coverage": 0.7,
    "avoid_consecutive": true,
    "preserve_academic_tone": true,
    "context_aware": true
  },
  "notes": [
    "替换率控制在60-70%之间，保留30%原始表达",
    "连续相同类别替换不超过3次",
    "专业术语、引用标记、数据数值不替换",
    "替换后需验证学术语气是否保持"
  ]
}
